# This is the only experiment-specific configuration.  Child experiments change
# these values while retaining the identical `bash reproduction/run_muirbench.sh`
# run contract.
VARIANT_NAME="sdpa_smoke_2"
CUDA_LAUNCH_BLOCKING="1"
DELIM_SCALING="False"
SCALE="8"
SELECT_LAYERS="0,1,2,3"
# Empty means the complete 2,600-example MuirBench test split. A smoke child
# changes this committed value while keeping the same run command.
EVAL_LIMIT="2"
